<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PinkPanther</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PinkPanther.styles.css" asp-append-version="true" />
</head>
<body>
    @{ 
        var currentAction = "";
        var actionObj = ViewContext?.RouteData?.Values?[
            "action"];
        if (actionObj != null)
        {
            currentAction = actionObj.ToString();
        }

        // Variables para las clases de enlace
        var clsIndex = "nav-link text-dark";
        var clsTienda = "nav-link text-dark";
        var clsPrivacy = "nav-link text-dark";

        if (currentAction == "Index") { clsIndex = clsIndex + " nav-link-activo"; }
        if (currentAction == "Tienda") { clsTienda = clsTienda + " nav-link-activo"; }
        if (currentAction == "Privacy") { clsPrivacy = clsPrivacy + " nav-link-activo"; }

        // Información de usuario 
        var puntos = "5,000";
        if (ViewData["PuntosUsuario"] != null) { puntos = ViewData["PuntosUsuario"].ToString() ?? puntos; }
        var nombreUsuario = "Ana García";
        if (ViewData["NombreUsuario"] != null) { nombreUsuario = ViewData["NombreUsuario"].ToString() ?? nombreUsuario; }
        var rolUsuario = "Jugador";
        if (ViewData["RolUsuario"] != null) { rolUsuario = ViewData["RolUsuario"].ToString() ?? rolUsuario; }
    }
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom box-shadow barra-principal">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/Imagenes/Whirlpool-imagen.png" alt="Whirlpool" width="150">
                </a>
                <div class="menu-superior">
                    <ul class="navbar-nav menu-centrado">
                        <li class="nav-item">
                            <a class="@clsIndex" asp-area="" asp-controller="Home" asp-action="Index">Catálogo</a>
                        </li>
                        <li class="nav-item">
                            <a class="@clsTienda" asp-area="" asp-controller="Home" asp-action="Tienda">Tienda de personalización</a>
                        </li>
                        <li class="nav-item">
                            <a class="@clsPrivacy" asp-area="" asp-controller="Home" asp-action="Privacy">Mi Perfil</a>
                        </li>
                    </ul>

                    <div class="panel-perfil">
                        <div class="pildora-puntos">
                            <span class="punto-moneda"></span>
                            @puntos
                        </div>
                        <div class="nombre-perfil">
                            <strong>@nombreUsuario</strong>
                            <span>@rolUsuario</span>
                        </div>
                        <div class="avatar-perfil"></div>
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container text-center">
            &copy; 2026 - Proyecto de Gamificación Whirlpool - Pantalla desarrollada por Ringo García
        </div>
    </footer>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
