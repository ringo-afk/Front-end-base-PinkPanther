@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PinkPanther</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PinkPanther.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/perfil.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/TablaClasificatoria.css" asp-append-version="true"/>
    
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @{ 
        var currentController = ViewContext?.RouteData?.Values?["controller"]?.ToString();
        var currentAction = ViewContext?.RouteData?.Values?["action"]?.ToString();

        var clsCatalogo = "nav-link text-dark";
        var clsTienda = "nav-link text-dark";
        var clsPrivacy = "nav-link text-dark";
        var clsLeaderboard = "nav-link text-dark";
        var clsJuego = "nav-link text-dark"; 

        if (currentController == "Home" && currentAction == "Catalogo") { clsCatalogo += " nav-link-activo"; }
        if (currentController == "Home" && currentAction == "Tienda") { clsTienda += " nav-link-activo"; }
        if (currentController == "Perfil" && currentAction == "Perfil") { clsPrivacy += " nav-link-activo"; }
        if (currentController == "Home" && currentAction == "TablaClasificatoria") { clsLeaderboard += " nav-link-activo"; }
        if (currentController == "Juego" && currentAction == "Juego") { clsJuego += " nav-link-activo"; }

        var puntos = Context.Session.GetInt32("PuntosUsuario")?.ToString("N0") ?? "0";
        var nombreUsuario = Context.Session.GetString("NombreUsuario") ?? "Usuario";
        var rolUsuario = "Jugador";
    }

    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom box-shadow barra-principal" style="padding: 15px 40px;">
            <div class="container-fluid">
                
                <a class="navbar-brand d-flex flex-column" asp-area="" asp-controller="Home" asp-action="Catalogo" style="text-decoration: none;">
                    <h1 style="margin: 0; font-size: 24px; color: #333; font-weight: bold;">
                        <img src="~/Imagenes/Whirlpool-imagen.png" alt="Whirlpool" style="height: 30px; vertical-align: middle;" /> 
                        <span style="color:#f6c042;">|</span> Learning Hub
                    </h1>
                    <p style="margin: 0; font-size: 14px; color: #666; padding-left: 5px;">Centro de Aprendizaje de IA</p>
                </a>
     
                @if (Context.Session.GetString("NombreUsuario") != null)
                {
                    <div class="menu-superior">
                        <ul class="navbar-nav menu-centrado" style="gap: 20px;">
                            <li class="nav-item">
                                <a class="@clsJuego" asp-area="" asp-controller="Home" asp-action="Juego">
                                    <i class="bi bi-controller me-1"></i> Jugar
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="@clsCatalogo" asp-area="" asp-controller="Home" asp-action="Catalogo">
                                    <i class="bi bi-book me-1"></i> Catálogo
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="@clsTienda" asp-area="" asp-controller="Home" asp-action="Tienda">
                                    <i class="bi bi-shop me-1"></i> Tienda
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="@clsLeaderboard" asp-area="" asp-controller="Home" asp-action="TablaClasificatoria">
                                    <i class="bi bi-trophy me-1"></i> Tabla
                                </a>
                            </li>
                            <li class="nav-item">
                                 <a class="@clsPrivacy" asp-area="" asp-controller="Perfil" asp-action="Perfil">
                                     <i class="bi bi-person-circle me-1"></i> Mi Perfil
                                 </a>
                            </li>
                        </ul>

                        <div class="panel-perfil d-flex align-items-center">
                            <div class="pildora-puntos me-3">
                                <span class="punto-moneda"></span>
                                @puntos
                            </div>
                            <div class="nombre-perfil me-3 text-end">
                                <strong>@nombreUsuario</strong>
                                <span>@rolUsuario</span>
                            </div>
                            
                            <div class="dropdown">
                                <div class="avatar-perfil" 
                                     data-bs-toggle="dropdown" 
                                     aria-expanded="false" 
                                     style="cursor: pointer; transition: 0.2s;"
                                     onmouseover="this.style.opacity='0.8'"
                                     onmouseout="this.style.opacity='1'">
                                    @nombreUsuario.Substring(0,1)
                                </div>
                                
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2" style="border-radius: 10px;">
                                    <li>
                                        <a class="dropdown-item py-2" asp-controller="Perfil" asp-action="Perfil">
                                            <i class="bi bi-person me-2"></i> Ir al Perfil
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item py-2 text-danger" asp-controller="Home" asp-action="Logout">
                                            <i class="bi bi-box-arrow-right me-2"></i> Cerrar Sesión
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container text-center">
            &copy; 2026 - Proyecto de Gamificación Whirlpool
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>