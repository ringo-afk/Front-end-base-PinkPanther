@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PinkPanther</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PinkPanther.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/perfil.css" asp-append-version="true" />
    
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @{ 
        var currentController = ViewContext?.RouteData?.Values?["controller"]?.ToString();
        var currentAction = ViewContext?.RouteData?.Values?["action"]?.ToString();

        var clsCatalogo = "nav-link text-dark";
        var clsTienda = "nav-link text-dark";
        var clsPrivacy = "nav-link text-dark";

        if (currentController == "Home" && currentAction == "Catalogo") { clsCatalogo += " nav-link-activo"; }
        if (currentController == "Home" && currentAction == "Tienda") { clsTienda += " nav-link-activo"; }
        if (currentController == "Perfil" && currentAction == "Perfil") { clsPrivacy += " nav-link-activo"; }

        var puntos = Context.Session.GetInt32("PuntosUsuario")?.ToString("N0") ?? "0";
        var nombreUsuario = Context.Session.GetString("NombreUsuario") ?? "Usuario";
        var rolUsuario = "Jugador";
    }

    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom box-shadow barra-principal" style="padding: 15px 40px;">
            <div class="container-fluid">
                
                <a class="navbar-brand d-flex flex-column" asp-area="" asp-controller="Home" asp-action="Index" style="text-decoration: none;">
                    <h1 style="margin: 0; font-size: 24px; color: #333; font-weight: bold;">
                        <img src="~/Imagenes/Whirlpool-imagen.png" alt="Whirlpool" style="height: 30px; vertical-align: middle;" /> 
                        <span style="color:#f6c042;">|</span> Learning Hub
                    </h1>
                    <p style="margin: 0; font-size: 14px; color: #666; padding-left: 5px;">Centro de Aprendizaje de IA</p>
                </a>
     
                @if (Context.Session.GetString("NombreUsuario") != null)
                {
                    <div class="menu-superior">
                        <ul class="navbar-nav menu-centrado" style="gap: 20px;">
                            <li class="nav-item">
                                <a class="@clsCatalogo" asp-area="" asp-controller="Home" asp-action="Catalogo">📖 Catálogo</a>
                            </li>
                            <li class="nav-item">
                                <a class="@clsTienda" asp-area="" asp-controller="Home" asp-action="Tienda">🛒 Tienda</a>
                            </li>
                            <li class="nav-item">
                                <a class="@clsPrivacy" asp-area="" asp-controller="Perfil" asp-action="Perfil">👤 Mi Perfil</a>
                            </li>
                        </ul>

                        <div class="panel-perfil">
                            <div class="pildora-puntos">
                                <span class="punto-moneda"></span>
                                @puntos
                            </div>
                            <div class="nombre-perfil">
                                <strong>@nombreUsuario</strong>
                                <span>@rolUsuario</span>
                            </div>
                            <div class="avatar-perfil"></div>
                        </div>
                    </div>
                }
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container text-center">
            &copy; 2026 - Proyecto de Gamificación Whirlpool - Pantalla desarrollada por Ringo García
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>